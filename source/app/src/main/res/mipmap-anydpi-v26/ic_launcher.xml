<?xml version="1.0" encoding="utf-8"?>
<!-- THABTHABA STORE clock logo.

     The foreground is a raster of the brand logo scaled into the middle ~66% of the 108dp
     canvas, because that is all the launcher mask guarantees — the gold bezel runs edge to edge
     in the source artwork, so a round or squircle mask would cut straight through it.

     The <monochrome> layer is deliberately gone: themed icons flatten their drawable to a single
     colour, and this logo is a black plate carrying a gold ring, a wordmark and a fine skyline.
     As one flat colour it becomes an unreadable blob, so letting Android fall back to the
     full-colour icon is the better answer. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
