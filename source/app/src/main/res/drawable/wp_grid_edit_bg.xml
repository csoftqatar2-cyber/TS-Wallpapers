<?xml version="1.0" encoding="utf-8"?>
<!-- Disc behind the pencil, so it reads as a button and not as part of the picture. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/colorAccent" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#CC0b0906" />
            <stroke android:width="1dp" android:color="@color/aurora_border" />
        </shape>
    </item>
</selector>
