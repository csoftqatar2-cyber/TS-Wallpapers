<?xml version="1.0" encoding="utf-8"?>
<!-- Switch track. On = the accent→gold gradient; off = a faint white wash.
     Sized 52x30dp per the design; the thumb is 24dp with 3dp of breathing room. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <size android:width="52dp" android:height="30dp" />
            <corners android:radius="15dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/colorAccent"
                android:endColor="@color/gold"
                android:type="linear" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <size android:width="52dp" android:height="30dp" />
            <corners android:radius="15dp" />
            <solid android:color="#1affffff" />
        </shape>
    </item>

</selector>
