<?xml version="1.0" encoding="utf-8"?>
<!-- The window background behind every AlertDialog in the app.
     Named *_panel_bg because @color/dialog_bg already exists and is a different thing. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="28dp"
    android:insetRight="28dp"
    android:insetTop="18dp"
    android:insetBottom="18dp">
    <shape android:shape="rectangle">
        <corners android:radius="18dp" />
        <solid android:color="@color/aurora_card" />
        <stroke android:width="1dp" android:color="@color/aurora_border" />
    </shape>
</inset>
