<?xml version="1.0" encoding="utf-8"?>
<!-- One of the five auto-switch intervals. Selected is a filled accent pill; the rest are
     outlines — so which one is chosen is readable across a car cabin, which a spinner's
     collapsed single line never was. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="@color/colorAccent" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#332e2417" />
            <stroke android:width="1dp" android:color="@color/gold" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#332e2417" />
            <stroke android:width="1dp" android:color="@color/gold" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#2e2417" />
            <stroke android:width="1dp" android:color="@color/aurora_border" />
        </shape>
    </item>

</selector>
