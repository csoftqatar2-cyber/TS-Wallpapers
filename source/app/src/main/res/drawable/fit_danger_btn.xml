<?xml version="1.0" encoding="utf-8"?>
<!-- Delete. Kept visually apart from Done: it is the one irreversible control on the screen. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#40ff6b5b" />
            <stroke android:width="2dp" android:color="@color/aurora_danger" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1aff6b5b" />
            <stroke android:width="1dp" android:color="#66ff6b5b" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
