<?xml version="1.0" encoding="utf-8"?>
<!-- Nav rail item. Selected is a solid accent→gold gradient carrying dark text; focus is a
     ring. Both states are specified because a d-pad user can focus one item while another
     is selected, and the two must never be confusable.
     Order matters: selected+focused has to be listed before either single state. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true" android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:angle="315"
                        android:startColor="@color/colorAccent"
                        android:endColor="@color/gold"
                        android:type="linear" />
                    <stroke android:width="2dp" android:color="@color/aurora_text" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33ff9a3d" />
            <stroke android:width="2dp" android:color="@color/colorAccent" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/colorAccent"
                android:endColor="@color/gold"
                android:type="linear" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</selector>
