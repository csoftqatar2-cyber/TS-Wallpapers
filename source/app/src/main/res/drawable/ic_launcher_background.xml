<?xml version="1.0" encoding="utf-8"?>
<!-- Icon background: the logo's own black plate, not the cream of the old mark.
     The logo is a black clock face with a gold bezel, so a light background would ring it with
     a bright halo on every launcher that applies a mask. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0.0" android:color="#FF16151A" />
                <item android:offset="1.0" android:color="#FF07070A" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
