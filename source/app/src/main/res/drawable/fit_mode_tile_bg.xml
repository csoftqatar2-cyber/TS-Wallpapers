<?xml version="1.0" encoding="utf-8"?>
<!-- Mode tile. The selected tile is the loudest thing in the control bar because it is the
     control that carries the whole feature. Focus is separate so a d-pad user can move across
     the tiles without changing the mode. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33ff9a3d" />
            <stroke android:width="2dp" android:color="@color/aurora_text" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#1affa03c" />
            <stroke android:width="2dp" android:color="@color/gold" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#08ffffff" />
            <stroke android:width="2dp" android:color="@color/aurora_border" />
            <corners android:radius="15dp" />
        </shape>
    </item>

</selector>
