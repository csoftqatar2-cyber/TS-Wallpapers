<?xml version="1.0" encoding="utf-8"?>
<!-- "Change" — deliberately grey and secondary. It sits next to the one button that commits
     the wallpaper, and the two must never be mistaken for each other at a glance. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#4d8b95a5" />
            <stroke android:width="2dp" android:color="@color/aurora_text" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4d8b95a5" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2e8b95a5" />
            <stroke android:width="1dp" android:color="#668b95a5" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
