<?xml version="1.0" encoding="utf-8"?>
<!-- Every setting is its own tile rather than a bare row inside one big card.
     The focused state has to survive being read from the driver's seat, so it gets the
     accent outline rather than the near-invisible hairline the resting state uses. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33ff9a3d" />
            <stroke android:width="2dp" android:color="@color/colorAccent" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1fff9a3d" />
            <stroke android:width="1dp" android:color="@color/aurora_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#07ffffff" />
            <stroke android:width="1dp" android:color="#0fffffff" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</selector>
