<?xml version="1.0" encoding="utf-8"?>
<!-- Serial field. Focus has to be readable from the driver's seat, hence the accent outline
     rather than the hairline the resting state uses (same rule as settings_row_bg). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1a0f0800" />
            <stroke android:width="2dp" android:color="@color/colorAccent" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#330f0800" />
            <stroke android:width="1dp" android:color="@color/aurora_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</selector>
