<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- the row itself handles the click (remote/TV friendly), so the box is not focusable -->
    <CheckBox
        android:id="@+id/checkBoxWallpaperVisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:focusable="false" />

    <ImageView
        android:id="@+id/imageViewWallpaperThumb"
        android:layout_width="88dp"
        android:layout_height="56dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="10dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/wallpaper_manage_title" />

    <TextView
        android:id="@+id/textViewWallpaperName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:maxLines="2"
        android:textSize="14sp" />
</LinearLayout>
