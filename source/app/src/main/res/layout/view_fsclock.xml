<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fsclockRootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <systems.sieber.fsclock.WallpaperView
        android:id="@+id/wallpaperView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/imageViewBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/linearLayoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/margin_main"
        android:gravity="center"
        android:orientation="vertical"
        android:divider="@drawable/divider_clock_vertical"
        android:showDividers="middle">

        <TextView
            android:id="@+id/textViewEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/events"
            android:textColor="@color/colorDefaultClock"
            android:textSize="25sp" />

        <GridLayout
            android:id="@+id/analogClockContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginLeft="@dimen/margin_clock"
            android:layout_marginRight="@dimen/margin_clock">

            <ImageView
                android:id="@+id/imageViewClockFace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/analog_classic_bg" />

            <ImageView
                android:id="@+id/imageViewClockHoursHand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/analog_classic_h" />

            <ImageView
                android:id="@+id/imageViewClockMinutesHand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/analog_classic_m" />

            <ImageView
                android:id="@+id/imageViewClockSecondsHand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_row="0"
                android:layout_column="0"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                app:srcCompat="@drawable/analog_classic_s" />
        </GridLayout>

        <LinearLayout
            android:id="@+id/digitalClockAndDateContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_gravity="fill_vertical"
            android:layout_weight="1"
            android:orientation="vertical">

            <systems.sieber.fsclock.DigitalClockView
                android:id="@+id/digitalClock"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="fill_vertical"
                android:gravity="bottom"
                android:layoutDirection="ltr"
                android:layout_weight="1"
                tools:ignore="NestedWeights" />

            <systems.sieber.fsclock.DateView
                android:id="@+id/textViewDate"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="1"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/clock_prefilled"
                android:textAlignment="center"
                android:textColor="@color/colorDefaultClock"
                app:autoSizeMaxTextSize="800dp"
                app:autoSizeMinTextSize="20dp"
                app:autoSizeStepGranularity="1px"
                app:autoSizeTextType="uniform" />

            <TextView
                android:id="@+id/textViewHijriDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:visibility="gone"
                android:textColor="@color/colorDefaultClock"
                android:textSize="22sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayoutBottomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="0dp"
        android:showDividers="middle"
        android:divider="@drawable/divider_statusbar"
        android:orientation="horizontal">
        <LinearLayout
            android:id="@+id/linearLayoutWeather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textViewWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text=""
                android:textColor="@color/colorDefaultClock"
                android:textSize="20sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/linearLayoutNotifications"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/imageViewNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="4dp"
                app:srcCompat="@drawable/ic_notifications_white_24dp" />
            <TextView
                android:id="@+id/textViewNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/colorDefaultClock"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayoutAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/imageViewAlarm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="4dp"
                app:srcCompat="@drawable/ic_alarm_white_24dp" />
            <TextView
                android:id="@+id/textViewAlarm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/clock_prefilled"
                android:textColor="@color/colorDefaultClock"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayoutBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/imageViewBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_battery_full_white_24dp" />
            <TextView
                android:id="@+id/textViewBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/battery_prefilled"
                android:textColor="@color/colorDefaultClock"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>
    <!-- Activation Overlay (shown only when the device is not activated in Supabase) -->
    <LinearLayout
        android:id="@+id/layoutActivation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f214100b"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- One centred card, split into two columns. Head-unit screens are wide and short
             (~2.67:1), so the old single 260dp column ran off the bottom: everything the user
             types is on the left, everything they choose is on the right, and neither column
             has to be tall. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/activation_card_bg"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Left: identify yourself and act. -->
                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/activation_overlay_title"
                        android:textColor="@color/gold"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/activation_overlay_subtitle"
                        android:textColor="@color/aurora_muted"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/editTextActivationSerial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/activation_input_bg"
                        android:textColor="@color/aurora_text"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:padding="12dp"
                        android:inputType="numberPassword"
                        android:hint="******"
                        android:textColorHint="@color/aurora_muted" />

                    <Button
                        android:id="@+id/buttonActivate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/activation_primary_btn"
                        android:textColor="#1a1204"
                        android:text="@string/activation_button"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/buttonRecheck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/fit_secondary_btn"
                        android:textColor="@color/aurora_text"
                        android:text="@string/activation_recheck_button"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:padding="10dp" />

                    <TextView
                        android:id="@+id/textViewActivationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/aurora_danger"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@color/aurora_border" />

                <!-- Right: operating mode. Was a lone "FSE" checkbox with nothing explaining
                     what FSE is; Leopard could not simply be glued next to it, because the two
                     are exclusive and a second checkbox would let both be ticked with no
                     answer for what that means. -->
                <LinearLayout
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_title"
                        android:textColor="@color/gold"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/mode_exclusive_note"
                        android:textColor="@color/aurora_muted"
                        android:textSize="11sp" />

                    <RadioGroup
                        android:id="@+id/radioGroupActivationMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/radioActivationNormal"
                            style="@style/ActivationModeRadio"
                            android:checked="true"
                            android:text="@string/mode_normal" />

                        <RadioButton
                            android:id="@+id/radioActivationFse"
                            style="@style/ActivationModeRadio"
                            android:text="@string/mode_fse" />

                        <RadioButton
                            android:id="@+id/radioActivationLeopard"
                            style="@style/ActivationModeRadio"
                            android:text="@string/mode_leopard" />

                    </RadioGroup>

                    <TextView
                        android:id="@+id/textViewActivationModeDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/aurora_muted"
                        android:textSize="11sp" />

                    <!-- The old checkbox stays, hidden: FsClockView and the settings screen
                         both still read it, and the radio above drives it. Removing it would
                         mean touching every read site in one go for no behavioural gain. -->
                    <CheckBox
                        android:id="@+id/checkBoxFse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:visibility="gone"
                        android:text="FSE" />
                </LinearLayout>
            </LinearLayout>

            <!-- Device ID: the one thing support asks for over the phone, so it stays on the
                 card, but quiet — it is read out, never acted on. -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:background="@drawable/chip_neutral_bg"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/activation_device_id_label"
                    android:textColor="@color/aurora_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/textViewActivationDeviceId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNKNOWN"
                    android:textColor="@color/aurora_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
