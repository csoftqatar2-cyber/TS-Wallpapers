<?xml version="1.0" encoding="utf-8"?>
<!-- Leopard picker. In Leopard the app is a tool you open, use for fifteen seconds, and close;
     it is not a place you look at. So this is transactional: two sources, a strip, one button.

     The two circles are a PERMANENT source switcher rather than a landing choice that
     disappears — on a screen this wide there is room for both, and staying put means a wrong
     turn costs one tap instead of a restart. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:id="@+id/leopardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- ===== top strip ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:baselineAligned="false">

        <ImageView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/logo_mark_light"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/aurora_text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:text="@string/leopard_title" />

        <TextView
            style="@style/HeaderChip"
            android:background="@drawable/chip_accent_bg"
            android:textColor="@color/gold"
            android:text="@string/leopard_chip" />

        <!-- The only route to Settings. In Leopard the clock screen never runs, and the gear
             that normally opens Settings lives on it — without this button the mode is a
             one-way door with no way back to Normal. -->
        <ImageView
            android:id="@+id/buttonLeopardSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:padding="10dp"
            android:background="@drawable/fit_secondary_btn"
            android:src="@drawable/ic_settings_white_24dp"
            android:tint="@color/aurora_text"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="@string/settings_header_title" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/aurora_border" />

    <!-- ===== body =====
         layoutDirection is pinned to LTR on purpose. "Cloud on the left, device on the right"
         is a physical instruction about the glass, not a start/end one — without this the whole
         row silently mirrors in Arabic and the technician's muscle memory breaks. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layoutDirection="ltr"
        android:baselineAligned="false">

        <!-- LEFT (physical): the cloud library -->
        <LinearLayout
            android:id="@+id/sourceCloud"
            style="@style/LeopardSource">
            <ImageView
                android:id="@+id/sourceCloudIcon"
                style="@style/LeopardSourceCircle"
                android:src="@drawable/ic_cloud_48dp" />
            <TextView
                android:id="@+id/sourceCloudLabel"
                style="@style/LeopardSourceLabel"
                android:text="@string/leopard_source_cloud" />
            <TextView
                style="@style/LeopardSourceSub"
                android:text="@string/leopard_source_cloud_sub" />
        </LinearLayout>

        <!-- filmstrip: a grid would waste a 2.67:1 band, and the cells are the screen's own
             shape so a cell reads as a preview of the result -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!-- fillViewport so the strip is at least as wide as the area it sits in. Without it
                 a HorizontalScrollView measures its child at wrap_content, so the QR — which is a
                 single box, not a strip — was pinned to the left edge instead of the middle.
                 (A match_parent on the strip cannot fix this: HorizontalScrollView measures its
                 child with an UNSPECIFIED width spec and ignores it.) -->
            <HorizontalScrollView
                android:id="@+id/filmstripScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:fillViewport="true"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:clipToPadding="false"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/filmstrip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp" />
            </HorizontalScrollView>

            <ProgressBar
                android:id="@+id/leopardProgress"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/colorAccent"
                android:visibility="gone" />

            <!-- one view for empty / offline / no-cache; the copy is what differs -->
            <LinearLayout
                android:id="@+id/leopardState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/leopardStateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/aurora_muted"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/leopardStateAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fit_secondary_btn"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:textColor="@color/aurora_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

        </FrameLayout>

        <!-- RIGHT (physical): the two "bring your own file" sources, stacked.
             The head-unit's own storage does NOT get a phone icon — this product has no phone
             in it and that circle opens local storage; a phone glyph would send the technician
             looking for a cable. The phone icon belongs to the QR upload underneath it, which
             is the one place a phone is genuinely involved. -->
        <LinearLayout
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/sourceLocal"
                style="@style/LeopardSourceCompact">
                <ImageView
                    android:id="@+id/sourceLocalIcon"
                    style="@style/LeopardSourceCircleCompact"
                    android:src="@drawable/ic_storage_48dp" />
                <TextView
                    android:id="@+id/sourceLocalLabel"
                    style="@style/LeopardSourceLabel"
                    android:text="@string/leopard_source_local" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sourcePhone"
                style="@style/LeopardSourceCompact"
                android:layout_marginTop="14dp">
                <ImageView
                    android:id="@+id/sourcePhoneIcon"
                    style="@style/LeopardSourceCircleCompact"
                    android:src="@drawable/ic_tile_phone_upload_32dp" />
                <TextView
                    android:id="@+id/sourcePhoneLabel"
                    style="@style/LeopardSourceLabel"
                    android:text="@string/leopard_source_phone" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ===== bottom ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="30dp"
        android:paddingEnd="30dp">

        <TextView
            android:id="@+id/buttonSetWallpaper"
            android:layout_width="wrap_content"
            android:minWidth="200dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_height="54dp"
            android:background="@drawable/fit_primary_btn"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:textColor="#1a1204"
            android:textSize="17sp"
            android:textStyle="bold"
            android:text="@string/leopard_set" />

        <TextView
            android:id="@+id/textViewLeopardStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="@color/aurora_muted"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>

<!-- ===================== full-screen preview =====================
     Picking from a filmstrip of 2.67:1 thumbnails is a guess; this is where you actually see
     the wallpaper before committing it. Confirm or go back, nothing else. -->
<FrameLayout
    android:id="@+id/leopardPreview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0b0906"
    android:visibility="gone"
    android:focusable="true"
    android:clickable="true">

    <ImageView
        android:id="@+id/leopardPreviewImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:importantForAccessibility="no" />

    <!-- A video used to preview as a flat brown rectangle with the word "video" on it, which is
         no basis for committing a dashboard to a clip. It is fetched first (the file is needed on
         disk to apply it anyway, so this costs nothing extra) and then played here, looping and
         muted, with the same Set / Change buttons underneath. -->
    <VideoView
        android:id="@+id/leopardPreviewVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Sits under the spinner: a car's link makes this a real wait, and "جارٍ التحميل 43%"
         is the difference between waiting and assuming it has hung. -->
    <TextView
        android:id="@+id/leopardPreviewLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:textColor="@color/aurora_text"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Scrim: the buttons sit on top of an arbitrary photo and have to stay readable on a
         white one. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/leopard_preview_scrim" />

    <TextView
        android:id="@+id/leopardPreviewBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="18dp"
        android:background="@drawable/fit_badge_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textColor="@color/gold"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="34dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/buttonPreviewSet"
            android:layout_width="wrap_content"
            android:minWidth="200dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_height="56dp"
            android:background="@drawable/fit_primary_btn"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:textColor="#1a1204"
            android:textSize="17sp"
            android:textStyle="bold"
            android:text="@string/leopard_set" />

        <TextView
            android:id="@+id/buttonPreviewChange"
            android:layout_width="wrap_content"
            android:minWidth="130dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_height="56dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/leopard_change_btn"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:textColor="@color/aurora_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="@string/leopard_change" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/leopardPreviewProgress"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/gold"
        android:visibility="gone" />

</FrameLayout>

</FrameLayout>
