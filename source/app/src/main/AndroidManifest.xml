<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- optional: use the real GPS/network location so the weather follows the car (falls back to typed city / IP when unavailable) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- required to install downloaded app updates (in-app self update) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- auto-start when the car head unit boots (optional feature, off by default) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- allows launching the activity from the background on Android 10+ -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- do not remove - still necessary for older API levels <= 22 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Leopard mode sets a still image as the system wallpaper via WallpaperManager.setBitmap().
         Without this the call throws SecurityException and every image fails while video still
         works, because video goes through the system's own live-wallpaper screen instead.
         Normal permission: granted at install, nothing to request at runtime. -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:name=".FsClockApp"
        android:allowBackup="true"
        android:largeHeap="true"
        android:usesCleartextTraffic="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@mipmap/ic_banner"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="UnusedAttribute">

        <activity
            android:name=".FitEditorActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/AppTheme" />

        <activity
            android:name=".LeopardPickerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/AppTheme" />

        <!-- Leopard: the live wallpaper Android offers in its own picker. Only ever used for
             moving content — still images go straight through WallpaperManager and never
             involve this service. -->
        <service
            android:name=".MediaWallpaperService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper" />
        </service>

        <service
            android:name=".FullscreenDream"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_round"
            android:label="@string/app_name_long"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.service.dream"
                android:resource="@xml/dream" />
        </service>

        <service android:name=".NotificationListener"
            android:label="NotificationListenerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            tools:targetApi="18">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <meta-data
                android:name="android.service.notification.default_filter_types"
                android:value="conversations|alerting">
            </meta-data>
            <meta-data
                android:name="android.service.notification.disabled_filter_types"
                android:value="ongoing|silent">
            </meta-data>
        </service>

        <activity
            android:name=".FullscreenActivity"
            android:configChanges="keyboardHidden|screenSize"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:banner="@mipmap/ic_banner"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver android:name=".PowerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
            </intent-filter>
        </receiver>

        <!-- Deliberately NOT directBootAware: our settings live in credential-protected storage,
             so a receiver running before unlock could not read them anyway, and touching that
             storage that early throws on some devices. BOOT_COMPLETED after unlock is enough. -->
        <receiver android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <!-- the car woke rather than booted: no BOOT_COMPLETED is sent, and this is the
                     case that made auto-start work only after a long park -->
                <action android:name="android.intent.action.USER_PRESENT" />
            </intent-filter>
            <intent-filter>
                <!-- come back up by ourselves after an in-app update replaces the APK -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Amazon IAP ResponseReceiver lives in src/amazon/AndroidManifest.xml so
             standalone/google builds no longer declare a receiver whose class
             doesn't exist in their flavor. -->

        <activity
            android:name=".SettingsActivity"
            android:label="@string/app_name_long"
            android:windowSoftInputMode="stateHidden" />

        <activity
            android:name=".FsClockWidgetDigitalConfigActivity"
            android:label="@string/widget_digital_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".FsClockWidgetAnalogConfigActivity"
            android:label="@string/widget_analog_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".FsClockWidgetDigitalProvider"
            android:exported="true"
            android:label="@string/widget_digital_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="systems.sieber.fsclock.DIGITAL_CLOCK_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_fsclock_digital" />
        </receiver>

        <receiver
            android:name=".FsClockWidgetAnalogProvider"
            android:exported="true"
            android:label="@string/widget_analog_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="systems.sieber.fsclock.ANALOG_CLOCK_WIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_fsclock_analog" />
        </receiver>

        <!-- FileProvider used to hand the downloaded update APK to the package installer -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
