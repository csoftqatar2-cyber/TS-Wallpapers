# Normalize line endings for text; leave binaries untouched
* text=auto

# Scripts that must stay LF
*.sh   text eol=lf
gradlew text eol=lf

# Windows scripts stay CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets
*.apk  binary
*.aab  binary
*.jks  binary
*.keystore binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.mp4  binary
*.jar  binary
*.class binary
*.pdf  binary
